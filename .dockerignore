# Keep the Docker build context lean. Everything the image needs at build time
# (pyproject.toml, uv.lock, README.md, and all of src/) is NOT excluded here.
# We deliberately KEEP src/ so `uv sync` can do its editable-style install that
# exposes craps_api plus its templates/static data files (see Dockerfile).

# Local virtualenv — the image builds its own.
.venv/

# Version control / CI metadata.
.git/
.gitignore
.github/

# Python caches and build artifacts.
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.ty_cache/
*.egg-info/
dist/
build/
htmlcov/
.coverage

# Docs and dev-only material not needed at runtime.
docs/notes/
PLANS.md

# The Docker files themselves.
Dockerfile
.dockerignore
